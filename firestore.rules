rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Prototype Rules (Insecure - No Firebase Auth)
    // ===============================================================
    // These rules allow anyone to read and write to the database.
    // In a production app, you would use Firebase Auth and secure these rules.
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
